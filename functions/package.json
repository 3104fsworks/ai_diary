{
  "name": "ai-diary-functions",
  "version": "1.0.0",
  "description": "Firebase Functions backend proxy for AI Diary",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "busboy": "^1.6.0",
    "express": "^4.19.2",
    "firebase-admin": "^12.3.0",
    "firebase-functions": "^5.0.1",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.5.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "private": true
}
